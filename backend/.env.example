# ─── Aplicação ───────────────────────────────────────────
APP_NAME=wwp-backend
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ─── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=changeme-admin-api-key
CORS_ORIGINS=["http://localhost:3000"]

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-jwt-secret-at-least-32-chars!!
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── PostgreSQL (externo — já rodando) ───────────────────
# Para rodar localmente (fora de Docker): use localhost
# Para containers Docker acessarem o host: use host.docker.internal
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wwp
POSTGRES_PASSWORD=wwp_secret
POSTGRES_DB=wwp
DATABASE_URL=postgresql+asyncpg://wwp:wwp_secret@host.docker.internal:5432/wwp
DATABASE_URL_SYNC=postgresql://wwp:wwp_secret@host.docker.internal:5432/wwp

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── MinIO / S3 ─────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wwp-media
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# ─── UazAPI ──────────────────────────────────────────────
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
UAZAPI_ADMIN_TOKEN=changeme-uazapi-admin-token

# ─── LLM / OpenAI ───────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-changeme
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ─── Webhook ─────────────────────────────────────────────
WEBHOOK_BASE_URL=https://seu-dominio.com
